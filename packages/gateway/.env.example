# RPC
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Contracts (Sepolia — do not change these)
CHAOS_CORE_ADDRESS=0x92cBc471D8a525f3Ffb4BB546DD8E93FC7EE67ca
REWARDS_DISTRIBUTOR_ADDRESS=0x84e4f06598D08D0B88A2758E33A6Da0d621cD517
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Auth — comma-separated API keys for write endpoints
CHAOSCHAIN_API_KEYS=cc_live_key1,cc_live_key2

# Signing key — wallet that submits transactions on behalf of the gateway
SIGNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Database — set automatically by Railway Postgres plugin, or provide manually
DATABASE_URL=postgresql://user:password@host:5432/chaoschain

# Network
NETWORK_NAME=sepolia
PORT=3000
METRICS_PORT=9090

# Arweave — leave empty for placeholder mode (no real uploads)
# Set USE_MOCK_ARWEAVE=true for local development
USE_MOCK_ARWEAVE=
TURBO_GATEWAY_URL=https://arweave.net
