# RPC
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Contracts (Sepolia — do not change these)
CHAOS_CORE_ADDRESS=0x92cBc471D8a525f3Ffb4BB546DD8E93FC7EE67ca
REWARDS_DISTRIBUTOR_ADDRESS=0x28AF9c02982801D35a23032e0eAFa50669E10ba1
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Reputation API — ReputationRegistry.getSummary requires at least one client address (studio).
# Comma-separated. If unset, defaults to Engineering Studio v2 on Sepolia.
# REPUTATION_CLIENT_ADDRESSES=0xFA0795fD5D7F58eCAa7Eae35Ad9cB8AED9424Dd0

# Auth — comma-separated seed API keys (loaded on startup)
# New keys should be created via POST /admin/keys
CHAOSCHAIN_API_KEYS=cc_internal_seed_key1

# Admin key — protects POST /admin/keys for issuing new API keys
# Generate with: node -e "console.log('cc_admin_' + require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=cc_admin_YOUR_SECRET_HERE

# Signing key — wallet that submits transactions on behalf of the gateway
SIGNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Treasury key (optional) — when set, after each closeEpoch the gateway calls StudioProxy.withdraw()
# so the 5% orchestrator fee is sent to this wallet. Must match RewardsDistributor.treasury().
# TREASURY_PRIVATE_KEY=0xYOUR_TREASURY_KEY_HERE

# Database — set automatically by Railway Postgres plugin, or provide manually
DATABASE_URL=postgresql://user:password@host:5432/chaoschain

# Network
NETWORK_NAME=sepolia
PORT=3000
METRICS_PORT=9090

# Arweave — leave empty for placeholder mode (no real uploads)
# Set USE_MOCK_ARWEAVE=true for local development
USE_MOCK_ARWEAVE=
TURBO_GATEWAY_URL=https://arweave.net

# Skills — optional; in Docker set to /app/chaoschain-skills (default: repo-relative)
# SKILLS_DIR=/app/chaoschain-skills
